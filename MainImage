        // --- Prompt Generation Core ---
        function generatePrompt() {
            // Gather all data
            const templateValue = document.querySelector('input[name="template"]:checked').value;
            const templateName = templateValue === 'tpl1' ? '【漱口杯風格】' : '【奶油切割盒風格】';
            
            const moodStyle = document.querySelector('input[name="moodStyle"]:checked').value;
            const category = document.querySelector('input[name="category"]:checked')?.value || '其他';
            
            const productName = document.getElementById('productName').value.trim() || '[未提供產品名稱]';
            const mainTitle = document.getElementById('mainTitle').value.trim();
            const subTitle = document.getElementById('subTitle').value.trim();
            const tagsText = document.getElementById('featureTags').value.trim();
            const tags = tagsText ? tagsText.split('\n').filter(t => t.trim() !== '') : [];
            const bottomText = document.getElementById('bottomText').value.trim();
            
            const showCircle = document.getElementById('showCircleToggle').checked;
            const circleText = document.getElementById('circleText').value.trim();
            
            const hasMainImage = !document.getElementById('mainImgPreview').classList.contains('hidden');

            // Build Prompt
            let p = `請以一位頂尖的「電商視覺設計師」與「產品包裝專家」的身份，幫我生成一張高轉換率的電商產品首圖（主圖）。\n\n`;
            
            p += `### 🛒 基礎設定\n`;
            p += `- 產品名稱 / 類別：${productName} (${category})\n`;
            p += `- 視覺氛圍 (Mood Style)：必須強烈展現「${moodStyle}」的色調、光影與質感。\n`;
            if (hasMainImage) {
                p += `- 產品主體：請參考我上傳的圖片作為產品主體外觀。\n`;
            } else {
                p += `- 產品主體：請在畫面合適位置生成逼真且符合「${productName}」的高質感產品照片。\n`;
            }
            p += `\n### 📐 排版與特效要求 (嚴格遵循)\n`;
            p += `請使用 ${templateName} 的經典版面結構：\n\n`;

            if (templateValue === 'tpl1') {
                p += `1. 整體構圖：畫面活潑明亮，適合兒童或居家用品。產品置於畫面中央偏右。\n`;
                
                if (mainTitle) {
                    p += `2. 主標題區 (頂部)：在畫面上方放置超大、醒目的卡通風格字體「${mainTitle}」。字體必須是明亮的橘色漸層填充，加上極粗的白色外框，帶有立體微陰影。\n`;
                } else {
                    p += `2. 主標題區：(用戶未提供，請勿生成任何頂部主標題文字)。\n`;
                }

                if (subTitle) {
                    p += `3. 副標題區 (右上角)：在畫面右上角，設計一個稍微傾斜的橫幅或區塊，背景為白色或淺綠色，裡面寫著清晰的文字「${subTitle}」。\n`;
                } else {
                    p += `3. 副標題區：(用戶未提供，請保持右上角無文字留白)。\n`;
                }

                if (tags.length > 0) {
                    p += `4. 賣點標籤 (左側)：在畫面左側中部，以上下排列的方式放置以下標籤，標籤外觀為白色圓角矩形：\n   - ${tags.map(t => `「${t}」`).join('\n   - ')}\n`;
                } else {
                    p += `4. 賣點標籤：(用戶未提供，請保持左側乾淨無文字)。\n`;
                }

                if (showCircle) {
                    p += `5. 圓形功能展示 (左下角)：在畫面左下方生成一個圓形畫框（橘色或亮色邊框），裡面展示產品細節或使用情境的特寫。`;
                    if (circleText) {
                        p += `在圓框的邊緣或下方，放置環繞式的文字「${circleText}」。\n`;
                    } else {
                        p += `(此區域不需添加文字)。\n`;
                    }
                }

                if (bottomText) {
                    p += `6. 底部宣傳列：畫面最下方添加一條綠色/亮色波浪或平滑底色橫條，上面用醒目對比色寫著「${bottomText}」。\n`;
                }

            } else {
                p += `1. 整體構圖：具有生活感、溫暖光暈的背景，將產品置於畫面中央偏左下方，呈現正在使用的狀態（例如有手部入鏡操作）。\n`;

                if (mainTitle) {
                    p += `2. 主標題區 (左上方)：字體排版緊湊，使用超大、極粗的白色字體，並加上深咖啡色/黑色的厚重外框「${mainTitle}」。\n`;
                    p += `3. 標題特效：標題周圍必須加入豐富的漫畫感特效！包括背景的黑色放射狀爆炸線條、點綴的白色閃光星星(✨)、以及漂浮在周圍的產品相關小元素。\n`;
                } else {
                    p += `2. 主標題與特效：(用戶未提供，左上方請保持乾淨的背景)。\n`;
                }

                if (tags.length > 0) {
                    p += `4. 賣點標籤 (右側)：在畫面右側，以上下排列的方式放置橢圓形的徽章標籤，標籤底色為米黃/溫暖色系，搭配深色文字，呈現高級質感：\n   - ${tags.map(t => `「${t}」`).join('\n   - ')}\n`;
                } else {
                    p += `4. 賣點標籤：(用戶未提供，右側請勿生成任何標籤文字)。\n`;
                }

                if (showCircle) {
                    p += `5. 圓形特寫區 (右下角)：在右下方放置一個白色邊框的圓形小圖，展示產品局部特寫或效果。`;
                    if (circleText) {
                        p += `在圓形區域旁邊加上文字標註「${circleText}」。\n`;
                    } else {
                        p += `\n`;
                    }
                }
                
                if (bottomText) {
                     p += `6. 其他文字：在畫面合適的空白處加上標語「${bottomText}」。\n`;
                }
            }

            p += `\n### ⚠️ 重要指示\n`;
            p += `1. **文字準確度**：請確保生成的圖片中，上述指定的繁體中文文字清晰可見且無錯字。\n`;
            p += `2. **留白與條件判斷**：我沒有提供的文字欄位，**絕對不可**自行發明文字填補，請保持該區域僅有背景或光影。\n`;
            p += `3. **高轉換率原則**：色彩對比要強烈，主體產品要大且清晰，一眼就能看出產品亮點。\n`;

            // Display
            document.getElementById('finalPromptText').value = p;
            document.getElementById('promptOutputArea').classList.remove('hidden');
            document.getElementById('promptOutputArea').classList.add('flex');
            
            // Scroll to output
            document.getElementById('promptOutputArea').scrollIntoView({ behavior: 'smooth', block: 'start' });
            
            showToast('Prompt 產生完成！');
        }

        // --- Utility Functions ---
        function copyPrompt() {
            const copyText = document.getElementById("finalPromptText");
            copyText.select();
            copyText.setSelectionRange(0, 99999);
            
            try {
                navigator.clipboard.writeText(copyText.value).then(() => {
                    showToast('已複製到剪貼簿！');
                }).catch(err => {
                    document.execCommand("copy");
                    showToast('已複製到剪貼簿！');
                });
            } catch (err) {
                 document.execCommand("copy");
                 showToast('已複製到剪貼簿！');
            }
            window.getSelection().removeAllRanges();
        }

        function showToast(msg) {
            const toast = document.getElementById('toast');
            document.getElementById('toastMsg').innerText = msg;
            toast.classList.remove('hidden');
            toast.classList.add('flex', 'toast-enter');
            
            setTimeout(() => {
                toast.classList.add('hidden');
                toast.classList.remove('flex', 'toast-enter');
            }, 3000);
        }

        function downloadPreview() {
            const container = document.getElementById('previewCanvasContainer');
            
            const btn = event.currentTarget;
            const originalHtml = btn.innerHTML;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> 處理中...';
            btn.disabled = true;

            html2canvas(container, {
                scale: 2,
                useCORS: true,
                backgroundColor: null,
                logging: false
            }).then(canvas => {
                const link = document.createElement('a');
                link.download = 'ec-hero-layout-preview.png';
                link.href = canvas.toDataURL('image/png');
                link.click();
                
                btn.innerHTML = originalHtml;
                btn.disabled = false;
                showToast('草圖下載完成！');
            }).catch(err => {
                console.error('Error generating canvas:', err);
                btn.innerHTML = originalHtml;
                btn.disabled = false;
                alert('下載發生錯誤，請稍後再試。');
            });
        }
    </script>
