<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI 電商首圖生成器 ✨ 爆款主圖一鍵產出</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- html2canvas -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;700;900&display=swap" rel="stylesheet">
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['"Noto Sans TC"', 'sans-serif'],
                    },
                    colors: {
                        brand: {
                            light: '#fff5f5',
                            DEFAULT: '#ff6b6b',
                            dark: '#fa5252',
                        }
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background-color: #f8fafc;
            background-image: radial-gradient(#cbd5e1 1px, transparent 1px);
            background-size: 20px 20px;
        }
        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #f1f1f1; border-radius: 4px; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
        
        /* Template 1 Specific Styles */
        .tpl-1-title {
            text-shadow: -3px -3px 0 #fff, 3px -3px 0 #fff, -3px 3px 0 #fff, 3px 3px 0 #fff, 4px 4px 0 #fb923c;
        }
        
        /* Template 2 Specific Styles */
        .tpl-2-title {
            text-shadow: -2px -2px 0 #451a03, 2px -2px 0 #451a03, -2px 2px 0 #451a03, 2px 2px 0 #451a03;
        }
        
        /* Glassmorphism */
        .glass-panel {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.5);
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05);
        }

        /* Toast Animation */
        @keyframes slideInUp {
            from { transform: translateY(100%); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }
        .toast-enter { animation: slideInUp 0.3s ease-out forwards; }
    </style>
</head>
<body class="text-slate-800 antialiased min-h-screen pb-20">

    <!-- Header -->
    <header class="bg-white/80 backdrop-blur-md sticky top-0 z-50 border-b border-slate-200 shadow-sm">
        <div class="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-gradient-to-br from-yellow-400 to-brand text-white rounded-xl flex items-center justify-center text-xl shadow-lg">
                    <i class="fa-solid fa-wand-magic-sparkles"></i>
                </div>
                <h1 class="text-2xl font-black bg-clip-text text-transparent bg-gradient-to-r from-brand-dark to-orange-500">
                    AI 電商首圖生成器 ✨
                </h1>
            </div>
            <div class="hidden md:flex gap-2">
                <button onclick="applyDemo('tpl1')" class="px-4 py-2 text-sm font-bold text-teal-600 bg-teal-50 rounded-lg border border-teal-200 hover:bg-teal-100 transition">
                    一鍵套用：漱口杯範例
                </button>
                <button onclick="applyDemo('tpl2')" class="px-4 py-2 text-sm font-bold text-amber-700 bg-amber-50 rounded-lg border border-amber-200 hover:bg-amber-100 transition">
                    一鍵套用：奶油盒範例
                </button>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 py-8 grid grid-cols-1 lg:grid-cols-12 gap-8">
        
        <!-- Left Panel: Controls -->
        <div class="lg:col-span-5 space-y-6">
            
            <!-- Section 1: Template Selection -->
            <div class="glass-panel rounded-2xl p-6">
                <h2 class="text-lg font-bold mb-4 flex items-center gap-2">
                    <i class="fa-solid fa-layer-group text-brand"></i> 1. 選擇排版模板 <span class="text-red-500">*</span>
                </h2>
                <div class="grid grid-cols-2 gap-4">
                    <label class="cursor-pointer relative group">
                        <input type="radio" name="template" value="tpl1" class="peer sr-only" checked onchange="updatePreview()">
                        <div class="border-2 border-slate-200 rounded-xl p-3 hover:border-brand-light peer-checked:border-brand peer-checked:bg-brand-light transition-all h-full flex flex-col items-center text-center">
                            <div class="w-full h-24 bg-teal-50 rounded-lg mb-2 relative overflow-hidden border border-slate-200">
                                <div class="absolute top-2 left-0 w-full text-center text-orange-500 font-black text-sm tpl-1-title">主標題</div>
                                <div class="absolute top-2 right-1 bg-white text-[8px] text-teal-600 px-1 rotate-6 rounded">副標題區</div>
                                <div class="absolute top-8 left-1 flex flex-col gap-1"><div class="w-8 h-3 bg-white rounded-full"></div></div>
                                <div class="absolute bottom-4 left-1 w-8 h-8 rounded-full border-2 border-orange-400 bg-white"></div>
                                <div class="absolute bottom-0 w-full h-4 bg-teal-400"></div>
                            </div>
                            <span class="font-bold text-slate-700">漱口杯風格 (模板1)</span>
                            <span class="text-xs text-slate-500 mt-1">頂部大字/左側標籤/圓形插圖/活潑</span>
                        </div>
                    </label>
                    <label class="cursor-pointer relative group">
                        <input type="radio" name="template" value="tpl2" class="peer sr-only" onchange="updatePreview()">
                        <div class="border-2 border-slate-200 rounded-xl p-3 hover:border-amber-100 peer-checked:border-amber-500 peer-checked:bg-amber-50 transition-all h-full flex flex-col items-center text-center">
                            <div class="w-full h-24 bg-amber-50 rounded-lg mb-2 relative overflow-hidden border border-slate-200 flex justify-center items-center">
                                <div class="absolute top-2 left-2 text-white font-black text-sm tpl-2-title text-left leading-tight">主標題<br>特效字</div>
                                <i class="fa-solid fa-star absolute top-2 right-10 text-yellow-400 text-[8px]"></i>
                                <i class="fa-solid fa-certificate absolute top-5 left-12 text-slate-800 text-[8px]"></i>
                                <div class="absolute top-8 right-2 flex flex-col gap-1 items-end">
                                    <div class="w-10 h-3 bg-[#fdf6e3] rounded-full border border-amber-900"></div>
                                    <div class="w-10 h-3 bg-[#fdf6e3] rounded-full border border-amber-900"></div>
                                </div>
                                <div class="absolute bottom-2 right-2 w-8 h-8 rounded-full border-2 border-white bg-white"></div>
                            </div>
                            <span class="font-bold text-slate-700">奶油切割盒 (模板2)</span>
                            <span class="text-xs text-slate-500 mt-1">左上標題/豐富特效/右側橢圓標籤/溫暖</span>
                        </div>
                    </label>
                </div>
            </div>

            <!-- Section 2: Mood Style & Category -->
            <div class="glass-panel rounded-2xl p-6">
                <h2 class="text-lg font-bold mb-4 flex items-center gap-2">
                    <i class="fa-solid fa-palette text-purple-500"></i> 2. 視覺風格與類別 <span class="text-red-500">*</span>
                </h2>
                
                <div class="mb-6">
                    <div class="flex items-center justify-between mb-2">
                        <label class="block text-sm font-bold text-slate-700">吸睛風格 (Mood Style)</label>
                    </div>
                    <div class="grid grid-cols-2 sm:grid-cols-4 gap-2" id="styleContainer">
                        <!-- Rendered by JS -->
                    </div>
                    <button id="toggleStylesBtn" class="mt-2 text-sm text-brand hover:underline font-medium w-full text-center" onclick="toggleStyles()">
                        展開更多風格 <i class="fa-solid fa-chevron-down"></i>
                    </button>
                </div>

                <div>
                    <div class="flex items-center justify-between mb-2">
                        <label class="block text-sm font-bold text-slate-700">產品類別</label>
                        <span class="text-xs text-slate-400">選擇最適合的商品情境</span>
                    </div>
                    <div class="grid grid-cols-2 sm:grid-cols-4 gap-2" id="categoryContainer">
                        <!-- Rendered by JS -->
                    </div>
                    <button id="toggleCategoriesBtn" class="mt-2 text-sm text-brand hover:underline font-medium w-full text-center" onclick="toggleCategories()">
                        展開全部 21 種分類 <i class="fa-solid fa-chevron-down"></i>
                    </button>
                </div>
            </div>

            <!-- Section 3: Text Content -->
            <div class="glass-panel rounded-2xl p-6">
                <h2 class="text-lg font-bold mb-4 flex items-center gap-2">
                    <i class="fa-solid fa-pen-nib text-blue-500"></i> 3. 文案內容
                </h2>
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-1">產品名稱 <span class="text-red-500">*</span></label>
                        <input type="text" id="productName" placeholder="例如：兒童漱口杯、奶油切割保鮮盒" class="w-full rounded-xl border-slate-300 border p-3 focus:ring-2 focus:ring-brand" oninput="updatePreview()">
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-1">超大主標題 (建議短而有力)</label>
                        <input type="text" id="mainTitle" placeholder="例如：漱口杯、奶油切割盒" class="w-full rounded-xl border-slate-300 border p-3 focus:ring-2 focus:ring-brand text-xl font-bold text-brand" oninput="updatePreview()">
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-1">副標題 / 賣點描述</label>
                        <input type="text" id="subTitle" placeholder="例如：孩子刷牙的好幫手" class="w-full rounded-xl border-slate-300 border p-3 focus:ring-2 focus:ring-brand" oninput="updatePreview()">
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-1">特色標籤 (每行一個，對應側邊標籤)</label>
                        <textarea id="featureTags" rows="3" placeholder="一杯兩用&#10;穩固升級&#10;防塵保鮮" class="w-full rounded-xl border-slate-300 border p-3 focus:ring-2 focus:ring-brand leading-relaxed" oninput="updatePreview()"></textarea>
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-1">底部 / 額外宣傳文字</label>
                        <input type="text" id="bottomText" placeholder="例如：三色可選、限時免運" class="w-full rounded-xl border-slate-300 border p-3 focus:ring-2 focus:ring-brand" oninput="updatePreview()">
                    </div>
                </div>
            </div>

            <!-- Section 4: Images & Details -->
            <div class="glass-panel rounded-2xl p-6">
                <h2 class="text-lg font-bold mb-4 flex items-center gap-2">
                    <i class="fa-solid fa-image text-green-500"></i> 4. 圖片與細節
                </h2>
                
                <div class="space-y-4">
                    <!-- Main Product Image (修正處：改用 label 解決點擊衝突) -->
                    <label for="mainImgInput" class="block border-2 border-dashed border-slate-300 rounded-xl p-4 text-center hover:bg-slate-50 transition cursor-pointer relative group">
                        <input type="file" id="mainImgInput" class="hidden" accept="image/*" onclick="this.value=null" onchange="handleImageUpload(event, 'mainImgPreview')">
                        <div class="group-hover:scale-105 transition-transform">
                            <i class="fa-solid fa-cloud-arrow-up text-3xl text-slate-400 mb-2"></i>
                            <p class="text-sm font-bold text-slate-700">點擊上傳產品主圖</p>
                            <p class="text-xs text-slate-500">建議使用透明背景去背圖 (PNG)</p>
                        </div>
                    </label>

                    <!-- Inset Content -->
                    <div class="bg-slate-50 p-4 rounded-xl border border-slate-200">
                        <div class="flex items-center justify-between mb-3">
                            <label class="block text-sm font-bold text-slate-700">圓形功能插圖區</label>
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input type="checkbox" id="showCircleToggle" class="sr-only peer" checked onchange="updatePreview()">
                                <div class="w-9 h-5 bg-slate-300 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-brand"></div>
                                <span class="ml-2 text-xs font-medium text-slate-600">啟用</span>
                            </label>
                        </div>
                        <div id="circleControls" class="space-y-3">
                            <div class="flex gap-3">
                                <!-- Circle Image Input (修正處：改用 label) -->
                                <label for="circleImgInput" class="w-16 h-16 rounded-full border-2 border-dashed border-slate-300 flex items-center justify-center cursor-pointer overflow-hidden bg-white shrink-0 hover:border-brand transition">
                                    <input type="file" id="circleImgInput" class="hidden" accept="image/*" onclick="this.value=null" onchange="handleImageUpload(event, 'circleImgView')">
                                    <img id="circleImgView" class="w-full h-full object-cover hidden">
                                    <i class="fa-solid fa-plus text-slate-400" id="circleImgIcon"></i>
                                </label>
                                <div class="flex-1">
                                    <input type="text" id="circleText" placeholder="圓框文字 (例: 通風瀝水)" class="w-full rounded-xl border-slate-300 border p-2 text-sm focus:ring-2 focus:ring-brand" oninput="updatePreview()">
                                    <p class="text-xs text-slate-500 mt-1">點擊左側圓框上傳細節圖</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- Right Panel: Preview & Output -->
        <div class="lg:col-span-7 space-y-6 flex flex-col">
            
            <!-- Live Preview Area -->
            <div class="glass-panel rounded-2xl p-6 flex-1 flex flex-col">
                <div class="flex justify-between items-center mb-4">
                    <h2 class="text-lg font-bold flex items-center gap-2">
                        <i class="fa-solid fa-eye text-indigo-500"></i> 排版示意預覽
                    </h2>
                    <button onclick="downloadPreview()" class="text-sm text-indigo-600 hover:bg-indigo-50 px-3 py-1 rounded-lg border border-indigo-200 transition">
                        <i class="fa-solid fa-download"></i> 下載草圖
                    </button>
                </div>
                
                <!-- PREVIEW CANVAS (Aspect Ratio 1:1) -->
                <div id="previewCanvasContainer" class="w-full max-w-md mx-auto aspect-square bg-slate-100 rounded-xl overflow-hidden shadow-inner relative flex-shrink-0 border-2 border-slate-200 transition-colors duration-500">
                    
                    <!-- Main Image Layer -->
                    <div class="absolute inset-0 flex items-center justify-center p-8 z-10" id="previewMainImgLayer">
                        <img id="mainImgPreview" class="max-w-full max-h-full object-contain hidden drop-shadow-2xl">
                        <div id="mainImgPlaceholder" class="text-slate-300 text-center">
                            <i class="fa-solid fa-box-open text-6xl mb-2"></i>
                            <p class="text-sm">尚未上傳產品圖</p>
                        </div>
                    </div>

                    <!-- Dynamic Layout Elements Container -->
                    <div id="dynamicLayoutLayer" class="absolute inset-0 z-20 pointer-events-none">
                        <!-- Content injected by JS -->
                    </div>
                    
                </div>
                <p class="text-center text-xs text-slate-400 mt-3">※ 此為排版位置示意圖，實際光影、特效與材質將由 AI 生成 ※</p>
            </div>

            <!-- Action Area -->
            <div class="glass-panel rounded-2xl p-6 border-l-4 border-brand">
                <h2 class="text-xl font-black mb-2 text-slate-800">準備好召喚爆款主圖了嗎？</h2>
                <p class="text-sm text-slate-600 mb-4">系統已自動將您的設定轉換為最適合 Gemini 生成圖片的專業 Prompt。</p>
                
                <button onclick="generatePrompt()" class="w-full py-4 bg-gradient-to-r from-brand to-orange-500 hover:from-brand-dark hover:to-orange-600 text-white rounded-xl font-black text-lg shadow-lg transform transition hover:scale-[1.02] active:scale-95 flex justify-center items-center gap-2">
                    <i class="fa-solid fa-wand-magic-sparkles"></i> 產生超強 AI 提示詞
                </button>
            </div>

            <!-- Output Prompt Area -->
            <div id="promptOutputArea" class="glass-panel rounded-2xl p-6 hidden flex-col">
                <div class="flex justify-between items-center mb-3">
                    <h3 class="font-bold text-slate-800 flex items-center gap-2">
                        <i class="fa-solid fa-terminal text-slate-600"></i> Gemini Prompt
                    </h3>
                    <div class="flex gap-2">
                        <button onclick="copyPrompt()" class="px-3 py-1.5 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-lg text-sm font-bold transition flex items-center gap-1">
                            <i class="fa-regular fa-copy"></i> 複製
                        </button>
                    </div>
                </div>
                <div class="relative">
                    <textarea id="finalPromptText" class="w-full h-64 p-4 rounded-xl border border-slate-300 bg-slate-50 text-sm font-mono leading-relaxed focus:ring-2 focus:ring-brand resize-none" readonly></textarea>
                </div>
                
                <div class="mt-4 p-4 bg-blue-50 border border-blue-100 rounded-xl flex items-start gap-3">
                    <i class="fa-solid fa-circle-info text-blue-500 mt-1"></i>
                    <div>
                        <p class="text-sm font-bold text-blue-900 mb-1">下一步：前往 Gemini 生成！</p>
                        <p class="text-xs text-blue-700 mb-3">複製上方的提示詞，點擊下方按鈕開啟 Gemini，貼上並送出即可獲得高品質首圖！如果之前有上傳「產品實拍圖」，建議一併上傳給 Gemini 參考。</p>
                        <a href="https://gemini.google.com/app" target="_blank" class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-bold rounded-lg transition">
                            前往 Gemini <i class="fa-solid fa-arrow-up-right-from-square"></i>
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </main>

    <!-- Custom Toast Message -->
    <div id="toast" class="fixed bottom-10 left-1/2 transform -translate-x-1/2 bg-slate-800 text-white px-6 py-3 rounded-full shadow-2xl z-50 hidden items-center gap-2 text-sm font-bold">
        <i class="fa-solid fa-circle-check text-green-400"></i>
        <span id="toastMsg">複製成功！</span>
    </div>

    <script>
        // --- Data Definitions ---
        const moodStyles = [
            { id: 'cute', name: '可愛萌趣', icon: 'fa-paw', color: 'text-pink-500' },
            { id: 'minimal', name: '文青簡約', icon: 'fa-leaf', color: 'text-emerald-500' },
            { id: 'warm', name: '溫暖光線', icon: 'fa-sun', color: 'text-amber-500' },
            { id: 'japanese', name: '日式和風', icon: 'fa-fan', color: 'text-red-400' },
            { id: 'energetic', name: '活力爆款', icon: 'fa-fire', color: 'text-orange-500' },
            { id: 'dreamy', name: '夢幻粉嫩', icon: 'fa-cloud', color: 'text-fuchsia-400' },
            { id: 'luxury', name: '奢華質感', icon: 'fa-gem', color: 'text-slate-700' },
            { id: 'tech', name: '科技未來', icon: 'fa-robot', color: 'text-blue-500' },
            { id: 'retro', name: '復古懷舊', icon: 'fa-camera-retro', color: 'text-yellow-700' },
            { id: 'fresh', name: '清新自然', icon: 'fa-seedling', color: 'text-green-500' }
        ];

        const categories = [
            // Top 8 Hot Categories
            { name: '家電', icon: 'fa-tv', color: 'text-blue-500' },
            { name: '生活用品', icon: 'fa-box-open', color: 'text-teal-500' },
            { name: '美妝保養', icon: 'fa-wand-magic-sparkles', color: 'text-pink-500' },
            { name: '服飾鞋包', icon: 'fa-shirt', color: 'text-purple-500' },
            { name: '3C 數位', icon: 'fa-laptop', color: 'text-indigo-500' },
            { name: '母嬰兒童', icon: 'fa-baby', color: 'text-orange-400' },
            { name: '食品飲料', icon: 'fa-utensils', color: 'text-red-500' },
            { name: '傢俱家居', icon: 'fa-couch', color: 'text-amber-600' },
            // Other Categories
            { name: '運動戶外', icon: 'fa-dumbbell', color: 'text-emerald-500' },
            { name: '汽機車用品', icon: 'fa-car', color: 'text-slate-600' },
            { name: '文具書籍', icon: 'fa-book', color: 'text-cyan-600' },
            { name: '玩具遊戲', icon: 'fa-gamepad', color: 'text-violet-500' },
            { name: '寵物用品', icon: 'fa-dog', color: 'text-orange-500' },
            { name: '醫療保健', icon: 'fa-kit-medical', color: 'text-rose-500' },
            { name: '珠寶飾品', icon: 'fa-ring', color: 'text-sky-500' },
            { name: '廚房衛浴', icon: 'fa-sink', color: 'text-blue-400' },
            { name: '清潔用品', icon: 'fa-broom', color: 'text-lime-600' },
            { name: '園藝植物', icon: 'fa-leaf', color: 'text-green-600' },
            { name: '辦公用品', icon: 'fa-paperclip', color: 'text-gray-500' },
            { name: '露營戶外', icon: 'fa-campground', color: 'text-amber-700' },
            { name: '其他', icon: 'fa-ellipsis', color: 'text-slate-400' }
        ];

        let showAllStyles = false;
        let showAllCategories = false;

        // --- Initialization ---
        document.addEventListener('DOMContentLoaded', () => {
            renderStyles();
            renderCategories();
            updatePreview();
        });

        // --- Render Functions ---
        function renderStyles() {
            const container = document.getElementById('styleContainer');
            container.innerHTML = '';
            const displayStyles = showAllStyles ? moodStyles : moodStyles.slice(0, 4);
            
            displayStyles.forEach((style, index) => {
                const isChecked = index === 0 && !document.querySelector('input[name="moodStyle"]:checked') ? 'checked' : ''; 
                const html = `
                    <label class="cursor-pointer relative">
                        <input type="radio" name="moodStyle" value="${style.name}" class="peer sr-only" ${isChecked} onchange="updatePreview()">
                        <div class="border border-slate-200 rounded-xl p-2 sm:p-3 text-center hover:bg-slate-50 peer-checked:border-brand peer-checked:bg-brand-light peer-checked:ring-1 peer-checked:ring-brand transition flex flex-col items-center gap-1">
                            <i class="fa-solid ${style.icon} ${style.color} text-lg sm:text-xl mb-1"></i>
                            <span class="text-xs sm:text-sm font-bold text-slate-700 whitespace-nowrap">${style.name}</span>
                        </div>
                    </label>
                `;
                container.insertAdjacentHTML('beforeend', html);
            });

            document.getElementById('toggleStylesBtn').innerHTML = showAllStyles 
                ? '收起風格 <i class="fa-solid fa-chevron-up"></i>'
                : '展開更多風格 <i class="fa-solid fa-chevron-down"></i>';
        }

        function toggleStyles() {
            showAllStyles = !showAllStyles;
            const selectedStyle = document.querySelector('input[name="moodStyle"]:checked')?.value;
            renderStyles();
            if (selectedStyle) {
                const radio = document.querySelector(`input[name="moodStyle"][value="${selectedStyle}"]`);
                if (radio) radio.checked = true;
                else document.querySelector('input[name="moodStyle"]').checked = true;
            }
        }

        function renderCategories() {
            const container = document.getElementById('categoryContainer');
            container.innerHTML = '';
            
            // Show top 8 by default, or all 21 if expanded
            const displayCategories = showAllCategories ? categories : categories.slice(0, 8);
            
            displayCategories.forEach((cat, index) => {
                const isChecked = index === 0 && !document.querySelector('input[name="category"]:checked') ? 'checked' : ''; 
                // Add a small "Hot" badge for the first 8 items if all are shown, just to differentiate (optional)
                const isHot = index < 8;
                const hotBadge = (showAllCategories && isHot) ? `<span class="absolute -top-1.5 -right-1.5 bg-red-500 text-white text-[9px] px-1.5 py-0.5 rounded-full font-bold shadow-sm">熱門</span>` : '';

                const html = `
                    <label class="cursor-pointer relative">
                        <input type="radio" name="category" value="${cat.name}" class="peer sr-only" ${isChecked}>
                        <div class="border border-slate-200 rounded-xl p-2 text-center hover:bg-slate-50 peer-checked:border-blue-500 peer-checked:bg-blue-50 peer-checked:ring-1 peer-checked:ring-blue-500 transition flex items-center justify-center gap-2 relative">
                            ${hotBadge}
                            <i class="fa-solid ${cat.icon} ${cat.color} text-sm"></i>
                            <span class="text-xs font-bold text-slate-700 whitespace-nowrap">${cat.name}</span>
                        </div>
                    </label>
                `;
                container.insertAdjacentHTML('beforeend', html);
            });

            document.getElementById('toggleCategoriesBtn').innerHTML = showAllCategories 
                ? '收起分類清單 <i class="fa-solid fa-chevron-up"></i>'
                : '展開全部 21 種分類 <i class="fa-solid fa-chevron-down"></i>';
        }

        function toggleCategories() {
            showAllCategories = !showAllCategories;
            const selectedCat = document.querySelector('input[name="category"]:checked')?.value;
            renderCategories();
            if (selectedCat) {
                const radio = document.querySelector(`input[name="category"][value="${selectedCat}"]`);
                if (radio) radio.checked = true;
                else document.querySelector('input[name="category"]').checked = true; // Default back to first if hidden
            }
        }

        // --- Image Upload Handling ---
        function handleImageUpload(event, previewElementId) {
            const file = event.target.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = function(e) {
                const img = document.getElementById(previewElementId);
                img.src = e.target.result;
                img.classList.remove('hidden');
                
                if (previewElementId === 'mainImgPreview') {
                    document.getElementById('mainImgPlaceholder').classList.add('hidden');
                } else if (previewElementId === 'circleImgView') {
                    document.getElementById('circleImgIcon').classList.add('hidden');
                }
                
                // ⚠️ 修正處：確保圖片載入完成後，立刻呼叫排版更新，讓圓形框內的圖片馬上出現
                updatePreview();
            }
            reader.readAsDataURL(file);
        }

        // --- Dynamic Preview Rendering ---
        function updatePreview() {
            // Get inputs
            const template = document.querySelector('input[name="template"]:checked').value;
            const mainTitle = document.getElementById('mainTitle').value.trim() || '主標題';
            const subTitle = document.getElementById('subTitle').value.trim();
            const tagsText = document.getElementById('featureTags').value.trim();
            const tags = tagsText ? tagsText.split('\n').filter(t => t.trim() !== '') : [];
            const bottomText = document.getElementById('bottomText').value.trim();
            const showCircle = document.getElementById('showCircleToggle').checked;
            const circleText = document.getElementById('circleText').value.trim();
            
            const layoutLayer = document.getElementById('dynamicLayoutLayer');
            const canvasContainer = document.getElementById('previewCanvasContainer');
            layoutLayer.innerHTML = '';

            // Update Circle Controls Visibility
            document.getElementById('circleControls').style.opacity = showCircle ? '1' : '0.4';
            document.getElementById('circleControls').style.pointerEvents = showCircle ? 'auto' : 'none';

            if (template === 'tpl1') {
                canvasContainer.className = 'w-full max-w-md mx-auto aspect-square bg-orange-50 rounded-xl overflow-hidden shadow-inner relative flex-shrink-0 border-2 border-slate-200 transition-colors duration-500';
                
                let html = '';
                // Top Title (Huge Orange Cartoon)
                html += `<div class="absolute top-4 left-0 w-full text-center z-30 px-4">
                            <h2 class="text-5xl font-black text-orange-500 tpl-1-title tracking-wide leading-tight">${mainTitle}</h2>
                         </div>`;
                         
                // Top Right Banner
                if (subTitle) {
                    html += `<div class="absolute top-6 right-2 z-30 transform rotate-12 bg-white px-3 py-1 rounded-full shadow-md border border-teal-100">
                                <span class="text-teal-600 font-bold text-sm italic">${subTitle}</span>
                             </div>`;
                }

                // Left Tags
                if (tags.length > 0) {
                    html += `<div class="absolute top-[30%] left-3 z-30 flex flex-col gap-3">`;
                    tags.forEach(tag => {
                        html += `<div class="bg-white text-teal-700 font-bold px-4 py-2 rounded-full shadow-md text-sm border-l-4 border-teal-500">${tag}</div>`;
                    });
                    html += `</div>`;
                }

                // Bottom Left Circle
                if (showCircle) {
                    const circleImgSrc = document.getElementById('circleImgView').src || '';
                    const imgHtml = circleImgSrc && !document.getElementById('circleImgView').classList.contains('hidden') 
                        ? `<img src="${circleImgSrc}" class="w-full h-full object-cover">` 
                        : `<div class="w-full h-full bg-teal-100 flex items-center justify-center text-teal-300 text-xs">細節</div>`;
                        
                    html += `<div class="absolute bottom-16 left-4 z-30 flex flex-col items-center">
                                <div class="w-24 h-24 rounded-full border-4 border-orange-400 overflow-hidden shadow-lg bg-white relative">
                                    ${imgHtml}
                                </div>
                                ${circleText ? `<div class="mt-[-10px] z-40 bg-orange-500 text-white text-xs font-bold px-3 py-1 rounded-full shadow-md transform -rotate-6 border-2 border-white">${circleText}</div>` : ''}
                             </div>`;
                }

                // Bottom Wavy Bar
                if (bottomText) {
                    html += `<div class="absolute bottom-0 left-0 w-full h-12 bg-teal-500 z-20 flex items-center justify-end pr-6 shadow-[0_-4px_10px_rgba(0,0,0,0.1)]">
                                <span class="text-white font-black text-lg tracking-widest">${bottomText}</span>
                             </div>`;
                }

                layoutLayer.innerHTML = html;

            } else if (template === 'tpl2') {
                canvasContainer.className = 'w-full max-w-md mx-auto aspect-square bg-[#fdf6e3] rounded-xl overflow-hidden shadow-inner relative flex-shrink-0 border-2 border-slate-200 transition-colors duration-500';
                
                let html = '';
                // Title & Effects
                html += `<div class="absolute top-8 left-6 z-30 max-w-[60%]">
                            <div class="relative">
                                <i class="fa-solid fa-certificate absolute -top-4 -left-4 text-slate-800 text-opacity-10 text-6xl z-[-1]"></i>
                                <i class="fa-solid fa-star absolute -top-2 right-0 text-yellow-400 text-xl animate-pulse"></i>
                                <h2 class="text-5xl font-black text-white tpl-2-title tracking-widest leading-tight">${mainTitle.replace(/(.{2})/g, '$1<br>')}</h2>
                            </div>
                         </div>`;

                // Right Tags (Oval Beige)
                if (tags.length > 0) {
                    html += `<div class="absolute top-[25%] right-4 z-30 flex flex-col items-end gap-3">`;
                    tags.forEach(tag => {
                        html += `<div class="bg-[#faebd7] text-[#5c4033] font-bold px-5 py-2 rounded-full shadow-sm border border-[#d2b48c] text-sm flex items-center gap-2">
                                    <span class="w-2 h-2 rounded-full bg-amber-500"></span>${tag}
                                 </div>`;
                    });
                    html += `</div>`;
                }

                // Bottom Right Circle
                if (showCircle) {
                    const circleImgSrc = document.getElementById('circleImgView').src || '';
                    const imgHtml = circleImgSrc && !document.getElementById('circleImgView').classList.contains('hidden') 
                        ? `<img src="${circleImgSrc}" class="w-full h-full object-cover">` 
                        : `<div class="w-full h-full bg-amber-100 flex items-center justify-center text-amber-300 text-xs">示意</div>`;
                        
                    html += `<div class="absolute bottom-6 right-6 z-30">
                                <div class="w-28 h-28 rounded-full border-4 border-white overflow-hidden shadow-xl bg-white relative">
                                    ${imgHtml}
                                </div>
                                ${circleText ? `<div class="absolute bottom-0 left-1/2 transform -translate-x-1/2 translate-y-1/2 bg-white text-amber-800 text-xs font-bold px-3 py-1 rounded-full shadow-md whitespace-nowrap">${circleText}</div>` : ''}
                             </div>`;
                }
                
                // Bottom Text
                if (bottomText) {
                    html += `<div class="absolute bottom-4 left-6 z-30 bg-amber-800 text-white px-4 py-1.5 rounded text-sm font-bold shadow-md">
                                ${bottomText}
                             </div>`;
                }

                layoutLayer.innerHTML = html;
            }
        }

        // --- Demo Data ---
        function applyDemo(type) {
            if (type === 'tpl1') {
                document.querySelector('input[name="template"][value="tpl1"]').checked = true;
                document.getElementById('productName').value = '兒童護齒漱口杯';
                document.getElementById('mainTitle').value = '漱口杯';
